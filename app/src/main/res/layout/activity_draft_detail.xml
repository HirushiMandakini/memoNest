<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="#F7F9FC">

    <TextView
        android:id="@+id/txtDetailTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Draft Title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#111827" />

    <TextView
        android:id="@+id/txtDetailDate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Date"
        android:textSize="12sp"
        android:textColor="#6B7280"
        android:layout_marginTop="8dp" />

    <ImageView
        android:id="@+id/imgDetail"
        android:layout_width="match_parent"
        android:layout_height="190dp"
        android:layout_marginTop="16dp"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <TextView
        android:id="@+id/txtDetailContent"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Draft content"
        android:textSize="16sp"
        android:textColor="#374151"
        android:lineSpacingExtra="5dp"
        android:layout_marginTop="24dp" />

    <Button
        android:id="@+id/btnEdit"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Edit Draft"
        android:textAllCaps="false"
        android:backgroundTint="#0D6EFD"
        android:textColor="#FFFFFF" />

    <Button
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Delete Draft"
        android:textAllCaps="false"
        android:backgroundTint="#DC2626"
        android:textColor="#FFFFFF"
        android:layout_marginTop="10dp" />

</LinearLayout>