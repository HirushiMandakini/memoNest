<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="28dp"
    android:gravity="center"
    android:background="#FFFFFF">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MemoNest"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#0D6EFD" />

    <ImageView
        android:layout_width="230dp"
        android:layout_height="170dp"
        android:layout_marginTop="45dp"
        android:src="@drawable/logo_container"
        android:scaleType="fitCenter"
        android:contentDescription="Onboarding image" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Offline Storage (SQLite)"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#111827"
        android:layout_marginTop="30dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Write anywhere and save your drafts locally, even without an internet connection."
        android:textSize="14sp"
        android:textColor="#6B7280"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:layout_marginTop="10dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="●  ○  ○"
        android:textSize="18sp"
        android:textColor="#0D6EFD"
        android:layout_marginTop="35dp" />

    <Button
        android:id="@+id/btnGetStarted"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:text="Get Started"
        android:textAllCaps="false"
        android:textSize="15sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:backgroundTint="#0D6EFD"
        android:layout_marginTop="35dp" />

</LinearLayout>